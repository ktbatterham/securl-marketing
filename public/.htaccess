Options -MultiViews
RewriteEngine On
RewriteBase /

# Serve privacy.html cleanly at /privacy
RewriteRule ^privacy$ /privacy.html [L]

# SPA fallback — everything else goes to index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]

# Security response headers.
# NOT wrapped in <IfModule mod_headers.c> — on Hostinger's LiteSpeed that guard
# evaluates false and silently skips the block. LiteSpeed honours these directly.
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "DENY"
# strict-origin-when-cross-origin (not no-referrer) so app.securl.online keeps securl.online attribution
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), browsing-topics=()"
Header always set Cross-Origin-Opener-Policy "same-origin"
Header always set Cross-Origin-Resource-Policy "same-origin"
